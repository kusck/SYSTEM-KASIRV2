generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  
}

enum CashType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model Transaction {
  id          String        @id @default(cuid())
  invoiceNo   String        @unique
  total       Int
  paidAmount  Int
  change      Int
  method      PaymentMethod @default(CASH)
  cashierName String        @default("Kasir")
  status      String        @default("Selesai")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  cashbooks   Cashbook[]

  @@map("transactions")
}

model Cashbook {
  id            String       @id @default(cuid())
  type          CashType
  category      String
  description   String
  amount        Int
  transactionId String?
  resetHistoryId String?
  cashierName   String       @default("Kasir")
  archivedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  resetHistory  CashbookDailyHistory? @relation(fields: [resetHistoryId], references: [id], onDelete: SetNull)

  @@map("cashbook")
}

model CashbookDailyHistory {
  id               String     @id @default(cuid())
  resetDate        String     @unique
  resetTime        String
  resetAt          DateTime
  totalIncome      Int
  totalExpense     Int
  endingBalance    Int
  transactionCount Int
  resetMode        String     @default("AUTO")
  createdBy        String     @default("System")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  cashbooks        Cashbook[]

  @@map("cashbook_daily_history")
}

model Product {
  id          String          @id @default(cuid())
  sku         String          @unique
  name        String
  category    String
  price       Int
  stock       Int             @default(0)
  minStock    Int             @default(0)
  imageUrl    String?
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  movements   StockMovement[]

  @@map("products")
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  type        StockMovementType
  quantity    Int
  stockBefore Int
  stockAfter  Int
  note        String?
  actorName   String            @default("Admin")
  createdAt   DateTime          @default(now())
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("stock_movements")
}
